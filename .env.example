# 🔑 REQUIRED: Gemini API Key
# Get from: https://aistudio.google.com
# 1. Visit the page above
# 2. Click "Get API Key"
# 3. Copy key here
GEMINI_API_KEY=your-actual-api-key-here

# 📱 Optional: Zalo Phone Number
# ZALO_PHONE=+84902273991

# 🔒 REQUIRED: MCP Server Auth Key
# Generate a secure random key (minimum 16 characters)
# Example: openssl rand -base64 32
# Or use any secure password generator
MCP_AUTH_KEY=your-secure-random-key-here

# 📧 Optional: Telegram Bot Token
# Get from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your-bot-token-here

# 📱 Optional: Telegram Chat ID
# Get from @userinfobot on Telegram
# TELEGRAM_CHAT_ID=your-chat-id-here

# ⚠️ SECURITY NOTES:
# - NEVER commit .env to Git (it's in .gitignore)
# - Keep API keys secret - they provide access to your account
# - Use strong, random MCP_AUTH_KEY
# - Rotate keys periodically
# - Use different keys for different environments (dev, prod)
